    "build:server": "node server/build.mjs",
    "start": "node server/dist/index.cjs",
    "dev": "pnpm run build && node server/dist/index.cjs",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate --config drizzle.config.js",
